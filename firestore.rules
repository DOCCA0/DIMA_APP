rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isRoomOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isActiveRoom(roomId) {
      let roomPath = /databases/$(database)/documents/studyRooms/$(roomId);
      return exists(roomPath) && get(roomPath).data.active == true;
    }

    function isRoomParticipant(roomId) {
      let participantPath = /databases/$(database)/documents/studyRooms/$(roomId)/participants/$(request.auth.uid);
      return isSignedIn() && exists(participantPath);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /sessions/{sessionId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /studyRooms/{roomId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          "name",
          "ownerId",
          "ownerName",
          "active",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.active == true
        && request.resource.data.createdAt == request.time;

      allow update: if isRoomOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "active"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.active is bool;

      allow delete: if isRoomOwner();

      match /participants/{userId} {
        allow read: if isSignedIn();

        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && isActiveRoom(roomId)
          && request.resource.data.keys().hasOnly([
            "displayName",
            "photoURL",
            "joinedAt",
            "cameraOn"
          ])
          && request.resource.data.displayName is string
          && request.resource.data.photoURL is string
          && request.resource.data.joinedAt == request.time
          && request.resource.data.cameraOn is bool;

        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /messages/{messageId} {
        allow read: if isRoomParticipant(roomId);

        allow create: if isRoomParticipant(roomId)
          && isActiveRoom(roomId)
          && request.resource.data.keys().hasOnly([
            "userId",
            "displayName",
            "text",
            "createdAt"
          ])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() > 0
          && request.resource.data.displayName.size() <= 80
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.createdAt == request.time;

        allow update, delete: if false;
      }
    }
  }
}
