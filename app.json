{
  "expo": {

    "name": "FocusRoom",
    "slug": "focusroom",
    "jsEngine": "jsc",
    "version": "1.0.0",
    "scheme": "focusroom",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.course.focusroom"
    },
    "android": {
      "package": "com.course.focusroom"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FocusRoom to use your camera in live study rooms.",
          "recordAudioAndroid": false
        }
      ],
      "expo-font",
      "expo-web-browser"
    ]
  }
}
